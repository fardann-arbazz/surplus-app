```gitignore
# =========================
# Laravel
# =========================

/public/hot
/public/storage
/storage/*.key
/storage/app/public
/storage/debugbar
/storage/framework/cache/*
/storage/framework/sessions/*
/storage/framework/testing/*
/storage/framework/views/*
/storage/logs/*
/bootstrap/cache/*

# Keep folders
!/storage/framework/cache/.gitignore
!/storage/framework/sessions/.gitignore
!/storage/framework/testing/.gitignore
!/storage/framework/views/.gitignore
!/storage/logs/.gitignore
!/bootstrap/cache/.gitignore

# =========================
# Environment Files
# =========================

.env
.env.backup
.env.production
.env.local
.env.*.local

# =========================
# Composer
# =========================

/vendor

# =========================
# Node / Vite
# =========================

/node_modules
/public/build
/public/mix-manifest.json
vite.svg

# =========================
# Testing
# =========================

/coverage
.phpunit.cache
.phpunit.result.cache

# =========================
# IDE / Editor
# =========================

.idea
.vscode
*.swp
*.swo
*~

# =========================
# OS Files
# =========================

.DS_Store
Thumbs.db

# =========================
# Logs
# =========================

npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =========================
# Docker
# =========================

docker-compose.override.yml

# =========================
# Misc
# =========================

*.pem
*.crt
*.key

# =========================
# Cache
# =========================

.php-cs-fixer.cache
eslintcache

# =========================
# Optional: Ignore uploaded files
# Uncomment if needed
# =========================

# /public/uploads
# /storage/app/uploads
```
